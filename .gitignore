# Minecraft Server — .gitignore

# Sensitive / Private Data
ops.json
whitelist.json
banned-players.json
banned-ips.json
usercache.json
server.properties
.console_history

# Plugin secrets
plugins/MabelBedrock/config.yml

# Logs & Cache
logs/
cache/
versions/
libraries/

# Generated / Runtime
plugins/.paper-remapped/
plugins/bStats/
plugins/spark/

# Server JAR (large binary, downloaded via PaperMC API)
paper.jar

# Plugin JARs (large binaries, included in release bundle)
plugins/*.jar

# Bundled runtime binaries
jre/

# Dev / IDE
.vscode/
.agents/
.windsurf/
backup dont push/

# Node modules
node_modules/
**/node_modules/

# OS files
Thumbs.db
desktop.ini
.DS_Store

# Release artifacts
release/
